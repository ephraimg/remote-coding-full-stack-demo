# Server Configuration
PORT=3000
NODE_ENV=production

# XRP Ledger Configuration
# Network URL - choose testnet or mainnet
XRP_NETWORK=wss://s.altnet.rippletest.net:51233
# Testnet: wss://s.altnet.rippletest.net:51233
# Mainnet: wss://xrplcluster.com

# CORS Configuration (production only)
# Comma-separated list of allowed origins
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Ephraim's XRP Address
# Get a testnet address from: https://xrpl.org/xrp-testnet-faucet.html
# This is used for balance checks and QR code generation
EXAMPLE_XRP_ADDRESS=

# Ephraim's XRP Address (for React app - must be prefixed with VITE_)
# REQUIRED: Application will fail to start without this
VITE_EXAMPLE_XRP_ADDRESS=

# EC2 Configuration (for deployment)
EC2_HOST=your-ec2-ip-here
EC2_USER=ec2-claude-user
