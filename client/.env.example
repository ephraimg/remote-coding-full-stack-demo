# Vite Environment Variables
# Variables must be prefixed with VITE_ to be exposed to the client-side code

# Example XRP Address for testing
# REQUIRED: Application will fail to start without this
# Get a testnet address from: https://xrpl.org/xrp-testnet-faucet.html
VITE_EXAMPLE_XRP_ADDRESS=

# API Base URL (optional, defaults to same origin)
# VITE_API_BASE_URL=http://localhost:3000
